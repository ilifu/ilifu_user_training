// Nextflow configuration for SLURM backend on ilifu cluster
// This file configures how Nextflow submits tasks to SLURM and manages resources

// Process configuration: defines resources for all tasks
process {
    // Default resource allocation for all processes
    // These can be overridden per-process or per-process-type
    cpus = 1
    memory = 2.GB
    time = 30.m

    // Override resources for specific process types (by name)
    // These match the process names in the .nf file

    withName: 'trim_reads' {
        cpus = 1
        memory = 2.GB
        time = 30.m
    }

    withName: 'align_sequences' {
        // Alignment is computationally intensive, request more resources
        cpus = 4
        memory = 8.GB
        time = 2.h
    }

    withName: 'count_alignments' {
        cpus = 1
        memory = 1.GB
        time = 10.m
    }

    withName: 'bias_correction' {
        cpus = 1
        memory = 2.GB
        time = 20.m
    }

    withName: 'flat_field_correction' {
        cpus = 1
        memory = 2.GB
        time = 20.m
    }

    withName: 'stack_images' {
        cpus = 2
        memory = 4.GB
        time = 1.h
    }
}

// Executor configuration: tells Nextflow to use SLURM
executor {
    // Use SLURM as the job scheduler
    name = 'slurm'

    // Queue management
    queueSize = 10          // Limit number of submitted jobs to prevent overwhelming the scheduler
    pollInterval = '30s'    // How often to check job status
    submitRateLimit = '10/1min'  // Don't submit more than 10 jobs per minute

    // Retry strategy for failed tasks
    maxRetries = 1
    maxErrors = '-1'  // Continue with other tasks if one fails
}

// Enable trace information (execution timeline)
trace {
    enabled = true
    file = 'trace.txt'
    sep = '\t'
}

// Generate timeline visualization (can be viewed in browser)
timeline {
    enabled = true
    file = 'timeline.html'
}

// Generate execution report
report {
    enabled = true
    file = 'report.html'
}

// Profiles: named configurations for different scenarios
profiles {
    // Standard profile for ilifu (default)
    standard {
        process.executor = 'slurm'
    }

    // Local profile for testing on login node (not recommended for long jobs)
    local {
        process.executor = 'local'
    }

    // High-resource profile for demanding workflows
    highres {
        process {
            cpus = 4
            memory = 16.GB
            time = 4.h
        }
        executor {
            queueSize = 5  // More conservative with resources
        }
    }
}

// Manifest: metadata about the workflow
manifest {
    name = 'Session 4 Tutorial 1 Workflows'
    description = 'Nextflow and WDL introduction for ilifu cluster'
    version = '1.0'
    author = 'ilifu User Training'
}
